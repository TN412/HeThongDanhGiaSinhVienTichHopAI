# GitHub Secrets Template
# Copy values to: Repository → Settings → Secrets and variables → Actions

# ========================================
# 1. DATABASE & STORAGE
# ========================================

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai_assessment_prod?retryWrites=true&w=majority

MONGODB_URI_TEST=mongodb+srv://username:password@cluster.mongodb.net/ai_assessment_test?retryWrites=true&w=majority

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=REPLACE_ME;AccountKey=REPLACE_ME;EndpointSuffix=core.windows.net


# ========================================
# 2. AUTHENTICATION & SECURITY
# ========================================

# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-REPLACE_ME


# ========================================
# 3. AZURE DEPLOYMENT
# ========================================

# Azure App Service name (backend)
AZURE_BACKEND_APP_NAME=your-backend-app-name

# Download from Azure Portal → App Service → Download publish profile
# Paste ENTIRE XML content here:
AZURE_WEBAPP_PUBLISH_PROFILE=<?xml version="1.0" encoding="utf-8"?>
<publishData>
  <publishProfile ... />
</publishData>

# Get from Azure Portal → Static Web Apps → Manage deployment token
AZURE_STATIC_WEB_APPS_API_TOKEN=REPLACE_ME

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.azurestaticapps.net


# ========================================
# 4. MONITORING (Optional)
# ========================================

# Get from Azure Portal → Application Insights → Instrumentation Key
APPINSIGHTS_INSTRUMENTATIONKEY=REPLACE_ME


# ========================================
# 5. FRONTEND BUILD
# ========================================

# Backend API URL for frontend
VITE_API_URL=https://your-backend.azurewebsites.net/api


# ========================================
# SETUP COMMANDS
# ========================================

# Generate JWT Secret:
# openssl rand -base64 32

# Azure CLI - Get Storage Connection String:
# az storage account show-connection-string --name ACCOUNT_NAME --resource-group RG_NAME

# Azure CLI - Get Static Web Apps Token:
# az staticwebapp secrets list --name APP_NAME --resource-group RG_NAME --query "properties.apiKey" -o tsv

# Azure CLI - Download Publish Profile:
# az webapp deployment list-publishing-profiles --name APP_NAME --resource-group RG_NAME --xml
